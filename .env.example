# =============================================================================
# RelatiV Backend — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# In production, set these via the platform's secret store (Vercel/Render/Fly).
#
# All variables are loaded by `backend/utils/config.py` (pydantic-settings).
# Anything marked REQUIRED will cause the app to refuse to start without it.
# =============================================================================

# ---- Application ----
APP_ENV=development                     # development | staging | production
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
PUBLIC_URL=http://localhost:9000        # Public base URL of this backend

# ---- Database (REQUIRED in production) ----
# Local docker-compose uses: postgresql+asyncpg://relativ:relativ@postgres:5432/relativ
DATABASE_URL=postgresql+asyncpg://relativ:relativ@localhost:5432/relativ

# ---- CORS ----
# Comma-separated list of origins allowed to call the API. The Vercel frontend
# URL is REQUIRED for production. localhost:3000 is for local dev only.
CORS_ORIGINS=http://localhost:3000

# ---- File storage ----
# Where rendered clips + intermediate artifacts land. In prod this MUST be a
# persistent volume (Render disk, Fly volume, or S3). Defaults to ./outputs.
OUTPUT_DIR=/data/outputs
MAX_UPLOAD_MB=2048                      # Cap on user-uploaded video files

# ---- Whisper transcription backend ----
# `local`      → faster-whisper runs in the same container (slower, free, 1.5 GB model)
# `runpod`     → POST audio to RUNPOD_WHISPER_URL, get segments back (faster, $$)
WHISPER_BACKEND=local
WHISPER_MODEL=small.en                  # tiny.en | base.en | small.en | medium.en | large-v3
WHISPER_DEVICE=cpu                      # cpu | cuda (only if you have a GPU)

# ---- RunPod Serverless (only if WHISPER_BACKEND=runpod) ----
RUNPOD_API_KEY=                         # sk-... from runpod.io/console/serverless
RUNPOD_WHISPER_URL=                     # https://api.runpod.ai/v2/<endpoint>/runsync

# ---- Anthropic / Claude (taste stage) ----
# REQUIRED for the new 9-stage pipeline's taste selector. Without this we fall
# back to a heuristic-only selector and clip quality drops ~30%.
ANTHROPIC_API_KEY=                      # sk-ant-... from console.anthropic.com
CLAUDE_MODEL=claude-haiku-4-5           # haiku is cheap + fast; sonnet for hard cases
CLAUDE_MAX_TOKENS=1024

# ---- YouTube fetcher ----
# Optional: path to a Netscape-format cookies.txt for age-gated / region-locked
# videos. Export from a logged-in YouTube session via "Get cookies.txt LOCALLY"
# browser extension. The repo's `cookies.txt` is .gitignored.
YOUTUBE_COOKIES_FILE=./cookies.txt

# ---- YouTube cost-saver path ----
# When true, the pipeline skips local audio download + faster-whisper for
# YouTube URLs and uses the YouTube transcript API directly. ~5× cheaper,
# slightly lower quality (no word-level timestamps). Default: true in prod.
YOUTUBE_COST_SAVER=true
