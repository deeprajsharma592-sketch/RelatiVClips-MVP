# RelatiV API. Caddy auto-issues Let's Encrypt cert for api.relativclips.com.
# Catch-all on :80 handles LE HTTP-01 ACME challenges + any legacy HTTP traffic.
# CORS is handled by FastAPI (see backend/main.py) — Caddy just proxies.

# Primary site: api.relativclips.com with auto-HTTPS
api.relativclips.com {
    reverse_proxy backend:9000
}

# Catch-all HTTP site: handles ACME challenges and any non-https traffic
:80 {
    reverse_proxy backend:9000
}
