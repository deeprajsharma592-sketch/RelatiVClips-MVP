# Secrets and large binaries — never commit
# YouTube auth cookies
cookies.txt
# Fallback face model (lives at repo root, ~6MB, too big for git)
yolov10n.pt
# Real face model, dropped into backend/models/ when ready
yolov10n-face.pt
# Any other pytorch weights or large binary checkpoints
*.pt
*.bin

# Agent handoff state (regenerated by each session, not code)
.relativ_state.json

# Junk folder (4 landing PNGs moved here for triage; may keep statefile)
junk/

